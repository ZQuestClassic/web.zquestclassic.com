DEFINE TINT_TEAL = 6;
DEFINE TINT_AMBER = 7;
DEFINE TINT_CYAN = 8;
DEFINE TINT_MODE_UNIFORM = 0;
DEFINE TINT_MODE_DISTRIBUTED = 1000;

