const int BUTTON_TILE = 0;
const int BUTTON_CSET = 1;
const int BUTTON_STATE = 2;
const int BUTTON_USER_DATA = 3;

const int BTNSTATE_NORMAL = 0;
const int BTNSTATE_UNDER_MOUSE = 1;
const int BTNSTATE_DOWN = 2;
const int BTNSTATE_DRAGGED_OFF = 3;

int Button_Create(int parent, int tile, int cset)
{
    int id=Widget_Create(WTYPE_BUTTON, parent);
    GUI_Data[id+WIDGET_WIDTH]=16;
    GUI_Data[id+WIDGET_HEIGHT]=16;
    GUI_Data[id+BUTTON_TILE]=tile;
    GUI_Data[id+BUTTON_CSET]=cset;
    GUI_Data[id+BUTTON_STATE]=BTNSTATE_NORMAL;
    GUI_Data[id+BUTTON_USER_DATA]=0;
    GUI_Data[id+WIDGET_FLAGS]|=WFLAG_WANTS_MOUSE;
    return id;
}

// Set data to send on click
void Button_SetUserData(int id, int data)
{
    GUI_Data[id+BUTTON_USER_DATA]=data;
}

void Button_Draw(int id, int x, int y)
{
    int tile=GUI_Data[id+BUTTON_TILE]+GUI_Data[id+BUTTON_STATE];
    Screen->FastTile(GUI_DRAW_LAYER, x, y, tile, GUI_Data[id+BUTTON_CSET], OP_OPAQUE);
}

void Button_OnMouseEnter(int id)
{
    if(GUI_Data[id+BUTTON_STATE]==BTNSTATE_DRAGGED_OFF)
        GUI_Data[id+BUTTON_STATE]=BTNSTATE_DOWN;
    else
        GUI_Data[id+BUTTON_STATE]=BTNSTATE_UNDER_MOUSE;
}

void Button_OnMouseExit(int id)
{
    if(GUI_Data[id+BUTTON_STATE]==BTNSTATE_DOWN)
        GUI_Data[id+BUTTON_STATE]=BTNSTATE_DRAGGED_OFF;
    else
        GUI_Data[id+BUTTON_STATE]=BTNSTATE_NORMAL;
}

void Button_OnMousePress(int id)
{
    GUI_Data[id+BUTTON_STATE]=BTNSTATE_DOWN;
}

void Button_OnMouseRelease(int id)
{
    if(GUI_Data[id+BUTTON_STATE]==BTNSTATE_DOWN)
    {
        GUI_Data[id+BUTTON_STATE]=BTNSTATE_UNDER_MOUSE;
        Event_Add(EVENT_BUTTON_CLICKED, id, GUI_Data[id+BUTTON_USER_DATA]);
    }
    else
        GUI_Data[id+BUTTON_STATE]=BTNSTATE_NORMAL;
}

const int CB_TILE = 0;
const int CB_CSET = 1;
const int CB_TEXT = 2;
const int CB_FONT = 3;
const int CB_TEXT_COLOR = 4;
const int CB_STATE = 5;

const int CBSTATE_UNDER_MOUSE = 001b;
const int CBSTATE_CLICKED     = 010b;
const int CBSTATE_CHECKED     = 100b;


int Checkbox_Create(int parent, int tile, int cset, int text, int font, int textColor)
{
    int id=Widget_Create(WTYPE_CHECKBOX, parent);
    GUI_Data[id+WIDGET_WIDTH]=8;
    GUI_Data[id+WIDGET_HEIGHT]=8;
    GUI_Data[id+CB_TILE]=tile;
    GUI_Data[id+CB_CSET]=cset;
    GUI_Data[id+CB_TEXT]=text;
    GUI_Data[id+CB_FONT]=font;
    GUI_Data[id+CB_TEXT_COLOR]=textColor;
    GUI_Data[id+CB_STATE]=0;
    GUI_Data[id+WIDGET_FLAGS]|=WFLAG_WANTS_MOUSE;
    return id;
}

void Checkbox_Draw(int id, int x, int y)
{
    int tile=GUI_Data[id+CB_TILE]+GUI_Data[id+CB_STATE];
    Screen->FastTile(GUI_DRAW_LAYER, x, y, tile, GUI_Data[id+CB_CSET], OP_OPAQUE);
    if(GUI_Data[id+CB_TEXT]!=0)
            Screen->DrawString(GUI_DRAW_LAYER,
              x+GUI_Data[id+WIDGET_WIDTH]+2, y,
              GUI_Data[id+CB_FONT], GUI_Data[id+CB_TEXT_COLOR], -1,
              TF_NORMAL, GUI_Data[id+CB_TEXT], OP_OPAQUE);
}

void Checkbox_OnMouseEnter(int id)
{
    GUI_Data[id+CB_STATE]|=CBSTATE_UNDER_MOUSE;
}

void Checkbox_OnMouseExit(int id)
{
    GUI_Data[id+CB_STATE]&=~CBSTATE_UNDER_MOUSE;
}

void Checkbox_OnMousePress(int id)
{
    GUI_Data[id+CB_STATE]|=CBSTATE_CLICKED;
}

void Checkbox_OnMouseRelease(int id)
{
    if((GUI_Data[id+CB_STATE]&CBSTATE_UNDER_MOUSE)!=0)
    {
        if((GUI_Data[id+CB_STATE]&CBSTATE_CHECKED)==0) // Unchecked -> Checked
        {
            GUI_Data[id+CB_STATE]|=CBSTATE_CHECKED;
            Event_Add(EVENT_CHECKBOX_CHANGED, id, 1);
        }
        else // Checked -> Unchecked
        {
            GUI_Data[id+CB_STATE]&=~CBSTATE_CHECKED;
            Event_Add(EVENT_CHECKBOX_CHANGED, id, 0);
        }
    }
    
    GUI_Data[id+CB_STATE]&=~CBSTATE_CLICKED;
}

const int GUI_ROOT = 0; // Root widget; parent of all top-level widgets

const int WFLAG_WANTS_MOUSE = 01b; // Accepts mouse input
const int WFLAG_HIDDEN      = 10b; // Invisible and unusable (applies to children)

int GUI_Events[90];
int GUI_EventPtr;
int GUI_EventIter;

void Event_Clear()
{
    GUI_EventPtr=0;
}

void Event_Add(int type, int sender, int data)
{
    GUI_Events[GUI_EventPtr]=type;
    GUI_Events[GUI_EventPtr+1]=sender;
    GUI_Events[GUI_EventPtr+2]=data;
    GUI_EventPtr+=3;
}

// No data
void Event_Add(int type, int sender)
{
    GUI_Events[GUI_EventPtr]=type;
    GUI_Events[GUI_EventPtr+1]=sender;
    GUI_Events[GUI_EventPtr+2]=0;
    GUI_EventPtr+=3;
}

void EventIter_Begin()
{
    GUI_EventIter=-3;
}

bool EventIter_Next()
{
    GUI_EventIter+=3;
    return GUI_EventIter<GUI_EventPtr;
}

int EventIter_GetType()
{
    return GUI_Events[GUI_EventIter];
}

int EventIter_GetSender()
{
    return GUI_Events[GUI_EventIter+1];
}

int EventIter_GetData()
{
    return GUI_Events[GUI_EventIter+2];
}

const int LABEL_STRING = 0;
const int LABEL_FONT = 1;
const int LABEL_COLOR = 2;

