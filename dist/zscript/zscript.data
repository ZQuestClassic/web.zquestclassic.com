}

int HitboxLeft(item a)
{
	return (a->X + a->HitXOffset);
}

int HitboxLeft(npc a)
{
	return (a->X + a->HitXOffset);
}

int HitboxLeft(ffc a)
{
	return a->X;
}

// Returns the X coordinate of the right edge of the hitbox.
