}

int HitboxRight(lweapon a)
{
	return (a->X + a->HitXOffset + a->HitWidth - 1);
}

int HitboxRight(item a)
{
	return (a->X + a->HitXOffset + a->HitWidth - 1);
}

int HitboxRight(npc a)
{
	return (a->X + a->HitXOffset + a->HitWidth - 1);
}

int HitboxRight(ffc a)
{
