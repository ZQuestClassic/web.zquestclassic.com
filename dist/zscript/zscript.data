// Version 1.3.3

const int __TANGO_CONTROL_CODES_ENABLED = 0;

// Dummy functions

int __Tango_RunStringControlCode(int pos)
{
    // This should never be called. If it is, we'll just end the string here.
    __Tango_Buffer[pos]=NULL;
    return 0;
}

int __Tango_GetNumSCCArgs(int code)
{
    return 0;
}
