				strcpy(buf, "Oracle Proportional");
				break;
				
			case FONT_DSPHANTOM:
				strcpy(buf, "Phantom");
				break;
				
			case FONT_DSPHANTOMP:
				strcpy(buf, "Phantom Proportional");
				break;
				
			case FONT_ATARI800:
				strcpy(buf, "Atari 800");
				break;
				
