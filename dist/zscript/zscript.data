}

void __Tango_LogUndefinedVar(float data)
{
    int str[]="An undefined variable was referenced: %f\n";
    printf(str, data);
}

void __Tango_LogIncompleteSCC(int data)
{
    int str[]="The message contains an incomplete string control code.";
