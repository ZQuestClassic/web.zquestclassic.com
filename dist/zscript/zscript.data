const int __GHI_PREV_SCREEN        = 7;

// Global flags
const int __GHGF_FLICKER = 01b;
const int __GHGF_SUSPEND = 10b;

// Get a normal direction (a DIR_ constant) from a number outside that range
int __NormalizeDir(int dir)
{
    // Already normal
    if(dir>=0 && dir<=7)
        return dir;
    
    // 8-15 go clockwise from up to up-left
    if(dir==8)
        return DIR_UP;
    if(dir==9)
        return DIR_RIGHTUP;
    if(dir==10)
        return DIR_RIGHT;
    if(dir==11)
        return DIR_RIGHTDOWN;
    if(dir==12)
        return DIR_DOWN;
    if(dir==13)
        return DIR_LEFTDOWN;
    if(dir==14)
        return DIR_LEFT;
    if(dir==15)
        return DIR_LEFTUP;
    
    // Out of range, probably -1
    return DIR_UP;
}
