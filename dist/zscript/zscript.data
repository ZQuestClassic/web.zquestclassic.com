		((l->Y)+l->HitYOffset+l->DrawYOffset), (((l->X)+l->HitXOffset+l->DrawXOffset)+l->HitWidth), (((l->Y)+l->HitYOffset+l->DrawYOffset)+l->HitHeight) );
