// DMaps, Screens, Rooms

//Screen Flag categories. Flags from each category are ORed together, starting with the first flag
//See Screen Data dialog for what flags are contained in each category. Use in Screen->Flags
enum
{
	SF_ROOMTYPE,
	SF_VIEW,
	SF_SECRETS,
	SF_WARP,
	SF_ITEMS,
	SF_COMBOS,
	SF_SAVE,
	SF_FFC,
	SF_WHISTLE,
	SF_MISC,
	SF_LAST
};

